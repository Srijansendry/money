# Supabase & PostgreSQL Database Connection
# Replace the placeholder values below with your actual Supabase project credentials

# PostgreSQL Database Connection String (Found in Supabase Dashboard -> Project Settings -> Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Project URL (Found in Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co

# Supabase Service Role Key (Found in Supabase Dashboard -> Project Settings -> API -> service_role secret)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
